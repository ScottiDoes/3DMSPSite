# SMTP settings for the contact form (/api/contact)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@nevadajames.com
SMTP_PASS=your-mailbox-password

# Inbox(es) that receive lead notifications — comma-separated for multiple
CONTACT_TO=info@nevadajames.com,scott.harris@nevadajames.com

# Which background to render. One of: network | starfield | grid | flat | image
# (unset → network). Changing this requires a rebuild/redeploy.
NEXT_PUBLIC_BACKDROP=network
# Path under /public used only when NEXT_PUBLIC_BACKDROP=image
# NEXT_PUBLIC_BACKDROP_IMAGE=/backdrop.jpg
